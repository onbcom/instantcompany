---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'InstantCompany.com | Turn Any Idea Into a Company in 60 Seconds',
  description = 'Stop overthinking and start building. Enter your basic concept and InstantCompany generates your brand, positioning, pricing, and copy instantly.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" is:inline></script>
</head>
<body class="antialiased selection:bg-emerald-500 selection:text-white text-gray-900 bg-gray-200 font-sans">
  <div class="mx-auto max-w-7xl border-l border-r border-dashed border-gray-300 min-h-screen relative bg-gray-50/50">
    <!-- Vertical Grid Lines Background -->
    <div class="absolute inset-0 pointer-events-none flex justify-between px-4 opacity-20 z-0">
      <div class="w-px h-full bg-gray-300"></div>
      <div class="w-px h-full bg-gray-300"></div>
      <div class="w-px h-full bg-gray-300"></div>
    </div>

    <main class="relative z-10 p-4 md:p-6 lg:p-8 space-y-6">
      <slot />
    </main>
  </div>
</body>
</html>
