---
---
<section class="grid grid-cols-1 lg:grid-cols-12 gap-6 pt-12">
  <!-- Col 1: Text -->
  <div class="lg:col-span-4 flex flex-col justify-between space-y-12 py-4">
    <div class="flex justify-between border-b border-gray-200 pb-4">
      <span class="text-sm text-black">01</span>
      <div class="flex gap-2 text-gray-400 text-xs">
        <span>02</span>
        <span>03</span>
        <span>04</span>
      </div>
    </div>

    <div>
      <h3 class="text-3xl lg:text-4xl text-gray-900 leading-tight mb-6 font-manrope font-medium tracking-tighter">
        The AI <br />
        <span class="text-gray-400 font-manrope font-medium tracking-tighter">Business</span> <br />
        Architect.
      </h3>
      <p class="text-lg text-gray-500 leading-relaxed mb-8">
        InstantCompany.com is the ultimate "zero-to-one" engine for entrepreneurs, side-hustlers, and makers. We bridge the gap between a vague thought and a tangible business asset. By leveraging advanced LLMs, we don't just give you a name; we build the entire foundational architecture of your next venture so you can skip the brainstorming and move straight to execution.
      </p>

      <a href="/stories" class="group inline-flex items-center gap-3 bg-gray-900 text-white pl-5 pr-2 py-2 rounded-full text-base font-medium hover:bg-gray-800 transition-all">
        <span>See Examples</span>
        <span class="bg-white text-black rounded-full w-8 h-8 flex items-center justify-center group-hover:scale-110 transition-transform">
          <iconify-icon icon="solar:arrow-right-up-linear" class="text-lg"></iconify-icon>
        </span>
      </a>
    </div>
  </div>

  <!-- Col 2: Card Light -->
  <div class="lg:col-span-4 relative group cursor-pointer">
    <div class="relative h-[500px] w-full rounded-3xl overflow-hidden bg-gray-200">
      <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800" alt="Clean Architecture" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/60"></div>
      <div class="absolute top-6 left-6 text-white mix-blend-difference">
        <p class="text-lg tracking-tight">Brand Identity</p>
        <p class="text-sm text-gray-300">Logo & Domains</p>
      </div>
      <div class="absolute bottom-6 w-full px-6 flex justify-between items-end text-white">
        <div>
          <p class="text-xl font-manrope font-medium tracking-tighter">Complete Visual Style</p>
          <button class="mt-4 flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm hover:bg-white/30 transition">
            Explore <iconify-icon icon="solar:add-circle-linear" class="text-base"></iconify-icon>
          </button>
        </div>
        <span class="text-5xl opacity-50 font-manrope font-medium tracking-tighter">02</span>
      </div>
    </div>
  </div>

  <!-- Col 3: Card Dark -->
  <div class="lg:col-span-4 relative group cursor-pointer">
    <div class="relative h-[500px] w-full rounded-3xl overflow-hidden bg-[#1a1a1a]">
      <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=800" alt="Dark Tech Texture" class="w-full h-full object-cover opacity-60 transition-transform duration-700 group-hover:scale-105" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/80"></div>
      <div class="absolute top-6 left-6 text-white">
        <p class="text-lg tracking-tight">Go-To-Market</p>
        <p class="text-sm text-gray-400">Positioning</p>
      </div>
      <div class="absolute bottom-6 w-full px-6 flex justify-between items-end text-white">
        <div class="max-w-[70%]">
          <p class="text-xl mb-2 font-manrope font-medium tracking-tighter">Launch Strategy</p>
          <p class="text-sm text-gray-400 line-clamp-2">Receive validated pricing models and structured UVPs for immediate use.</p>
          <a href="/#generator" class="mt-4 flex items-center gap-2 bg-white text-black px-4 py-2 rounded-full text-sm hover:bg-gray-200 transition w-fit">
            Read More <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
          </a>
        </div>
        <span class="absolute bottom-6 right-6 text-5xl opacity-50 font-manrope font-medium tracking-tighter">03</span>
      </div>
    </div>

    <!-- Navigation Below Grid -->
    <div class="flex justify-end mt-4 gap-3">
      <button class="w-10 h-10 rounded-full border border-gray-300 flex items-center justify-center hover:border-gray-900 transition text-gray-500 hover:text-gray-900">
        <iconify-icon icon="solar:arrow-left-linear" class="text-lg"></iconify-icon>
      </button>
      <button class="w-10 h-10 rounded-full bg-gray-900 text-white flex items-center justify-center hover:bg-black transition">
        <iconify-icon icon="solar:arrow-right-linear" class="text-lg"></iconify-icon>
      </button>
    </div>
  </div>
</section>
