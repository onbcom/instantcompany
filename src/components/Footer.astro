---
---
<footer class="mt-8 w-full bg-[#050505] rounded-[2.5rem] overflow-hidden relative shadow-2xl border border-white/5">
  <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-emerald-600/10 rounded-full blur-[120px] pointer-events-none -translate-x-1/3 translate-y-1/3"></div>

  <!-- CTA Section -->
  <div class="pt-24 pb-16 px-8 text-center relative z-10">
    <div class="mx-auto w-20 h-20 bg-emerald-900/20 rounded-2xl flex items-center justify-center mb-8 border border-emerald-500/20 shadow-[0_0_40px_rgba(16,185,129,0.15)] backdrop-blur-sm">
      <div class="w-12 h-12 bg-emerald-500/10 rounded-lg flex items-center justify-center border border-emerald-500/30">
        <iconify-icon icon="solar:card-linear" class="text-emerald-400 text-2xl drop-shadow-[0_0_8px_rgba(52,211,153,0.5)]"></iconify-icon>
      </div>
    </div>

    <h2 class="text-4xl md:text-5xl lg:text-6xl text-white mb-6 font-manrope font-medium tracking-tighter">Your next big thing is 60 seconds away.</h2>
    <p class="text-gray-400 text-lg mb-10 max-w-lg mx-auto leading-relaxed">Join 10,000+ founders who used InstantCompany to stop dreaming and start building in 2026.</p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/#generator" class="px-8 py-3 rounded-full bg-gradient-to-b from-emerald-500 to-emerald-700 text-white hover:brightness-110 transition-all shadow-[0_0_25px_rgba(16,185,129,0.2)] flex items-center gap-2 border border-emerald-400/20">
        Start Generating Now <iconify-icon icon="solar:arrow-right-linear" class="text-lg"></iconify-icon>
      </a>
    </div>
  </div>

  <!-- Divider -->
  <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent w-full my-8 opacity-50"></div>

  <!-- Links Section -->
  <div class="px-8 md:px-16 pb-8 grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10">
    <!-- Brand Column -->
    <div class="lg:col-span-5 space-y-6">
      <h3 class="text-3xl text-white font-manrope font-medium tracking-tighter">InstantCompany<span class="text-emerald-500 font-manrope font-medium tracking-tighter">.com</span></h3>
      <p class="text-gray-500 text-sm leading-relaxed max-w-sm">
        Stop overthinking and start building. The ultimate AI business architect for ambitious founders.
      </p>
    </div>

    <!-- Links Columns -->
    <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-8 lg:pl-12">
      <div class="space-y-6">
        <h4 class="text-white">Product</h4>
        <ul class="space-y-3 text-sm text-gray-500">
          <li><a href="/#generator" class="hover:text-emerald-400 transition-colors">Generate Idea</a></li>
          <li><a href="/pricing" class="hover:text-emerald-400 transition-colors">Pricing</a></li>
          <li><a href="/stories" class="hover:text-emerald-400 transition-colors">Success Stories</a></li>
        </ul>
      </div>
      <div class="space-y-6">
        <h4 class="text-white">Resources</h4>
        <ul class="space-y-3 text-sm text-gray-500">
          <li><a href="/#how-it-works" class="hover:text-emerald-400 transition-colors">How it Works</a></li>
          <li><a href="/ai-generator" class="hover:text-emerald-400 transition-colors">Industries</a></li>
          <li><a href="/stories" class="hover:text-emerald-400 transition-colors">Blog</a></li>
        </ul>
      </div>
      <div class="space-y-6 hidden sm:block">
        <h4 class="text-white">Company</h4>
        <ul class="space-y-3 text-sm text-gray-500">
          <li><a href="#" class="hover:text-emerald-400 transition-colors">About Us</a></li>
          <li><a href="#" class="hover:text-emerald-400 transition-colors">Contact</a></li>
          <li><a href="#" class="hover:text-emerald-400 transition-colors">Terms & Privacy</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Compliance Footer -->
  <div class="border-t border-white/5 mt-8 py-8 px-8 md:px-16 relative z-10 text-center md:text-left">
    <p class="text-xs text-gray-600 leading-relaxed">
      &copy; 2026 InstantCompany.com. All rights reserved. Created for the next generation of builders. Not a legal service; please consult with professionals for formal business registration. AI-generated content is for inspirational purposes. Entrepreneurship involves risk.
    </p>
  </div>
</footer>
