---
---
<section id="how-it-works" class="py-24 relative overflow-hidden border-b border-gray-200/60 bg-white/50">
  <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-soft-light pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center rounded-full border border-gray-200 bg-white/80 backdrop-blur-sm px-3 py-1 text-xs text-gray-500 mb-6 shadow-sm">
        Process
      </div>
      <h2 class="text-4xl md:text-5xl text-gray-900 mb-6 leading-[1.1] font-manrope font-medium tracking-tighter">
        How It Works
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
        From idea to launch-ready in four simple steps.
      </p>
    </div>

    <!-- 4 Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Step 1: Input Your Idea -->
      <div class="group flex flex-col items-center text-center">
        <div class="relative h-56 w-full flex items-center justify-center mb-8 rounded-2xl bg-white border border-gray-100 shadow-[0_4px_20px_rgb(0,0,0,0.03)] overflow-hidden transition-all duration-500 group-hover:shadow-[0_12px_30px_rgb(0,0,0,0.06)] group-hover:border-emerald-100">
          <div class="absolute inset-0 opacity-40 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMCwwLDAsMC4wNSkiLz48L3N2Zz4=')] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
          <div class="relative z-10 w-4/5">
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-4 transform transition-all duration-500 group-hover:-translate-y-1">
              <div class="flex gap-2 items-center mb-3">
                <div class="w-2.5 h-2.5 rounded-full bg-red-400/20 border border-red-400/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/20 border border-yellow-400/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400/20 border border-emerald-400/50"></div>
              </div>
              <div class="flex items-center gap-3 bg-gray-50 p-2.5 rounded-lg border border-gray-100">
                <iconify-icon icon="solar:magic-stick-3-linear" class="text-emerald-500 text-lg"></iconify-icon>
                <div class="h-1.5 w-1/2 bg-gray-300 rounded-full"></div>
                <div class="w-0.5 h-3 bg-emerald-500 animate-pulse ml-1"></div>
              </div>
            </div>
          </div>
        </div>
        <h3 class="text-lg text-gray-900 mb-3 tracking-tight">Step 1: Input Your Idea</h3>
        <p class="text-sm text-gray-500 leading-relaxed max-w-xs mx-auto">
          Describe what you want to build in plain English.
        </p>
      </div>

      <!-- Step 2: AI Synthesis -->
      <div class="group flex flex-col items-center text-center">
        <div class="relative h-56 w-full flex items-center justify-center mb-8 rounded-2xl bg-white border border-gray-100 shadow-[0_4px_20px_rgb(0,0,0,0.03)] overflow-hidden transition-all duration-500 group-hover:shadow-[0_12px_30px_rgb(0,0,0,0.06)] group-hover:border-emerald-100">
          <div class="absolute inset-0 opacity-40 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMCwwLDAsMC4wNSkiLz48L3N2Zz4=')] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
          <div class="relative z-10 w-full flex items-center justify-center h-full">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-32 h-32 rounded-full border border-dashed border-emerald-500/30 animate-spin-slow"></div>
              <div class="absolute w-24 h-24 rounded-full border border-gray-200"></div>
            </div>
            <div class="relative bg-white w-14 h-14 rounded-2xl shadow-lg border border-gray-100 flex items-center justify-center transform transition-transform duration-500 group-hover:scale-110">
              <iconify-icon icon="solar:cpu-linear" class="text-emerald-500 text-2xl"></iconify-icon>
              <div class="absolute -right-1 -top-1 w-3 h-3 bg-emerald-400 rounded-full border-2 border-white"></div>
            </div>
            <div class="absolute top-8 left-8 bg-white p-2 rounded-lg shadow-sm border border-gray-100 transform transition-transform group-hover:-translate-x-2 group-hover:-translate-y-2">
              <iconify-icon icon="solar:chart-square-linear" class="text-gray-400"></iconify-icon>
            </div>
            <div class="absolute bottom-8 right-8 bg-white p-2 rounded-lg shadow-sm border border-gray-100 transform transition-transform group-hover:translate-x-2 group-hover:translate-y-2">
              <iconify-icon icon="solar:users-group-rounded-linear" class="text-gray-400"></iconify-icon>
            </div>
          </div>
        </div>
        <h3 class="text-lg text-gray-900 mb-3 tracking-tight">Step 2: AI Synthesis</h3>
        <p class="text-sm text-gray-500 leading-relaxed max-w-xs mx-auto">
          Our engine creates a brand identity, visual concepts, and market positioning.
        </p>
      </div>

      <!-- Step 3: Launch Strategy -->
      <div class="group flex flex-col items-center text-center">
        <div class="relative h-56 w-full flex items-center justify-center mb-8 rounded-2xl bg-white border border-gray-100 shadow-[0_4px_20px_rgb(0,0,0,0.03)] overflow-hidden transition-all duration-500 group-hover:shadow-[0_12px_30px_rgb(0,0,0,0.06)] group-hover:border-emerald-100">
          <div class="absolute inset-0 opacity-40 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMCwwLDAsMC4wNSkiLz48L3N2Zz4=')] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
          <div class="relative z-10 w-4/5">
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-4 transform transition-all duration-500 group-hover:-translate-y-1">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 bg-emerald-50 rounded-lg flex items-center justify-center border border-emerald-100">
                  <iconify-icon icon="solar:tag-price-linear" class="text-emerald-600 text-base"></iconify-icon>
                </div>
                <div class="flex-1">
                  <div class="h-2 w-3/4 bg-gray-200 rounded-full mb-1"></div>
                  <div class="h-1.5 w-1/2 bg-gray-100 rounded-full"></div>
                </div>
              </div>
              <div class="flex gap-2">
                <div class="h-6 flex-1 bg-emerald-50 rounded border border-emerald-100 flex items-center justify-center text-[10px] text-emerald-600 font-medium">$29/mo</div>
                <div class="h-6 flex-1 bg-gray-50 rounded border border-gray-100 flex items-center justify-center text-[10px] text-gray-400">$99/mo</div>
              </div>
            </div>
          </div>
        </div>
        <h3 class="text-lg text-gray-900 mb-3 tracking-tight">Step 3: Launch Strategy</h3>
        <p class="text-sm text-gray-500 leading-relaxed max-w-xs mx-auto">
          Receive a tailored pricing model and high-conversion landing page copy.
        </p>
      </div>

      <!-- Step 4: Export & Execute -->
      <div class="group flex flex-col items-center text-center">
        <div class="relative h-56 w-full flex items-center justify-center mb-8 rounded-2xl bg-white border border-gray-100 shadow-[0_4px_20px_rgb(0,0,0,0.03)] overflow-hidden transition-all duration-500 group-hover:shadow-[0_12px_30px_rgb(0,0,0,0.06)] group-hover:border-emerald-100">
          <div class="absolute inset-0 opacity-40 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMCwwLDAsMC4wNSkiLz48L3N2Zz4=')] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
          <div class="relative z-10 w-4/5">
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-4 transform transition-all duration-500 group-hover:-translate-y-1">
              <div class="flex justify-between items-start mb-4">
                <div class="w-10 h-10 bg-emerald-50 rounded-lg flex items-center justify-center border border-emerald-100">
                  <iconify-icon icon="solar:case-minimalistic-linear" class="text-emerald-600 text-xl"></iconify-icon>
                </div>
                <span class="bg-emerald-50 text-emerald-600 border border-emerald-200 text-[9px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-full">Output Ready</span>
              </div>
              <div class="space-y-2">
                <div class="h-2 w-3/4 bg-gray-200 rounded-full"></div>
                <div class="h-2 w-1/2 bg-gray-100 rounded-full"></div>
              </div>
              <div class="mt-4 pt-3 border-t border-gray-50 flex gap-2">
                <div class="h-7 flex-1 bg-gray-50 rounded border border-gray-100 flex items-center justify-center">
                  <iconify-icon icon="solar:global-linear" class="text-gray-400 text-sm"></iconify-icon>
                </div>
                <div class="h-7 flex-1 bg-gray-50 rounded border border-gray-100 flex items-center justify-center">
                  <iconify-icon icon="solar:pen-linear" class="text-gray-400 text-sm"></iconify-icon>
                </div>
              </div>
            </div>
          </div>
        </div>
        <h3 class="text-lg text-gray-900 mb-3 tracking-tight">Step 4: Export & Execute</h3>
        <p class="text-sm text-gray-500 leading-relaxed max-w-xs mx-auto">
          Take your full business blueprint and go live.
        </p>
      </div>
    </div>
  </div>
</section>
