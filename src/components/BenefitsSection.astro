---
---
<section class="overflow-hidden bg-gray-50 border-gray-200/60 border-b pt-24 pb-24 relative">
  <div class="lg:px-8 max-w-[1400px] mr-auto ml-auto pr-6 pl-6">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-20 gap-8">
      <h2 class="text-4xl md:text-5xl lg:text-6xl text-gray-900 max-w-4xl leading-[1.05] font-manrope font-medium tracking-tighter">
        Key Benefits
      </h2>
      <a href="/#generator" class="group inline-flex items-center text-sm text-gray-900 hover:text-emerald-600 transition-colors border-b border-gray-900 hover:border-emerald-600 pb-0.5 whitespace-nowrap">
        View Example Output
        <iconify-icon icon="solar:arrow-right-up-linear" class="ml-1 text-lg transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"></iconify-icon>
      </a>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Card 1: Eliminate Analysis Paralysis -->
      <div class="bg-white p-8 min-h-[520px] flex flex-col justify-between hover:shadow-[0_20px_40px_rgba(0,0,0,0.04)] transition-shadow duration-500 group rounded-3xl">
        <div>
          <h3 class="text-xl text-gray-900 mb-6 leading-snug font-manrope font-medium tracking-tighter">
            Eliminate<br />Analysis Paralysis
          </h3>
          <p class="text-gray-500 leading-relaxed text-sm">
            Get a professional foundation without spending weeks on brainstorming. Go from raw thought to structured venture instantly.
          </p>
        </div>
        <div class="flex items-center gap-3 pt-6 border-t border-gray-100 mt-auto">
          <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-1.2.1&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="Sarah J." class="w-10 h-10 rounded-full object-cover bg-gray-100 grayscale group-hover:grayscale-0 transition-all duration-500" />
          <div>
            <p class="text-sm text-gray-900">Sarah J.</p>
            <p class="text-xs text-gray-500">Founding Designer</p>
          </div>
        </div>
      </div>

      <!-- Card 2: Market-Ready Messaging -->
      <div class="relative min-h-[520px] bg-gray-900 overflow-hidden group rounded-3xl">
        <img src="https://images.unsplash.com/photo-1561070791-2526d30994b5?auto=format&fit=crop&w=800" alt="Brand Colors Abstract" class="group-hover:scale-105 group-hover:opacity-60 transition-all duration-700 opacity-70 w-full h-full object-cover absolute top-0 right-0 bottom-0 left-0" />
        <div class="bg-gradient-to-t from-black/80 via-transparent to-black/20 absolute top-0 right-0 bottom-0 left-0"></div>
        <div class="absolute top-8 left-8 right-8 flex justify-between items-start z-10">
          <span class="text-white text-lg tracking-tight mix-blend-overlay">Market-Ready Messaging&copy;</span>
        </div>
        <div class="absolute bottom-8 left-8 right-8 z-10">
          <p class="text-white text-sm mb-4 max-w-[200px]">Lean on data-driven positioning that resonates with your specific target audience.</p>
          <span class="text-white/60 text-xs uppercase tracking-widest">Smart Analysis</span>
        </div>
      </div>

      <!-- Card 3: Consistent Branding -->
      <div class="min-h-[520px] flex flex-col overflow-hidden group text-center bg-white p-8 relative items-center justify-between rounded-3xl">
        <p class="text-gray-500 text-lg mt-8">Consistent Branding &<br /> Coherent Identity</p>
        <div class="relative flex items-center justify-center w-56 h-56 my-8">
          <svg class="w-full h-full transform -rotate-90 drop-shadow-xl" viewBox="0 0 200 200">
            <circle cx="100" cy="100" r="90" stroke="#f3f4f6" stroke-width="1.5" fill="none"></circle>
            <circle cx="100" cy="100" r="90" stroke="#10b981" stroke-width="1.5" fill="none" stroke-dasharray="565" stroke-dashoffset="0" class="transition-all duration-1000 ease-out group-hover:stroke-[3]"></circle>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center flex-col">
            <span class="text-4xl text-gray-900 font-manrope font-medium tracking-tighter">100%</span>
            <span class="text-xs text-gray-500 mt-1">Validated UVP</span>
          </div>
        </div>
      </div>

      <!-- Card 4: Optimized Monetization -->
      <div class="min-h-[520px] flex flex-col group overflow-hidden text-white bg-[#0f1115] p-8 relative justify-between rounded-3xl">
        <div class="flex justify-between items-start z-10">
          <span class="text-xl font-manrope font-medium tracking-tighter">Optimized Monetization</span>
          <iconify-icon icon="solar:arrow-right-up-linear" class="text-gray-500 group-hover:text-white group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300"></iconify-icon>
        </div>
        <div class="z-10 relative">
          <p class="text-gray-400 leading-relaxed mb-12 max-w-[260px] text-sm">
            Stop guessing your value; get pricing models based on industry standards and AI analysis.
          </p>
          <div class="space-y-2 text-sm text-gray-400">
            <a href="/pricing" class="block hover:text-emerald-400 transition-colors">Pitch Deck Exports</a>
            <a href="/ai-generator" class="block hover:text-emerald-400 transition-colors">Copy Frameworks</a>
            <a href="/ai-generator" class="block hover:text-emerald-400 transition-colors">Go-To-Market Plans</a>
          </div>
        </div>
        <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-emerald-500/10 rounded-full blur-[80px] group-hover:bg-emerald-500/20 transition-all duration-700 pointer-events-none"></div>
      </div>
    </div>
  </div>
</section>
